<odoo>
    <data>
        <record id="planned_preventive_wizard_form" model="ir.ui.view">
            <field name="name">planned.preventive.wizard</field>
            <field name="model">planned.preventive.wizard</field>
            <field name="arch" type="xml">
                <form string="Validate Spare Parts">
                    <field name="name" invisible="1"/>
                    <field name="user_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="tasks"/>
                            <field name="product_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="interval"/>
                            <field name="task_duration"/>
                        </group>
                    </group>
                    <div class="o_row mb-3">

                        <button name="action_apply"
                                string="⟳ Apply to All"
                                type="object"
                                class="btn-primary"/>
                    </div>
                    <notebook>
                        <page string="Plan">
                                <field name="preventive_maintenance_plan_ids">
                                    <list editable="bottom">
                                        <field name="equipment_id" options="{'no_create': True}"/>
                                        <field name="tasks"/>
                                        <field name="interval"/>
                                        <field name="task_duration"/>
                                        <field name="unit_measure"/>
                                        <field name="different"/>
                                        <field name="product_ids" widget="many2many_tags"
                                               options="{'no_create': True}"/>
                                        <field name="to_day" invisible="1" readonly="1" optional="hide"/>
                                    </list>
                                </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

        <record id="planned_preventive_wizard_action" model="ir.actions.act_window">
            <field name="name">Planned Preventive</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">planned.preventive.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>

</odoo>